          <mxGeometry x="620" y="612" width="71.43" height="40" as="geometry" />
        </mxCell>
        <mxCell id="5Ef1XUkZ2bMFREay9JOX-13" value="Comunicação" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
          <mxGeometry x="605.7099999999999" y="662" width="100" height="30" as="geometry" />
        </mxCell>
        <mxCell id="lxHM5vcbzngOYg_8LYll-1" value="Engenheiro de Software" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
          <mxGeometry x="240" y="710" width="20" height="38" as="geometry" />
        </mxCell>
        <mxCell id="lxHM5vcbzngOYg_8LYll-2" value="Engenheiro de Hardware" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" parent="1" vertex="1">
          <mxGeometry x="390" y="710" width="20" height="38" as="geometry" />
        </mxCell>
        <mxCell id="d9EJzN6xdbAWGbnfFITx-1" value="&lt;b style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 18px; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; background-color: rgb(236, 236, 236); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;u&gt;Engenharia de Dados e Integração IoT&lt;/u&gt;&lt;/b&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="290" y="90" width="380" height="50" as="geometry" />
